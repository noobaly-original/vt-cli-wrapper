# VirusTotal CLI Wrapper Environment Variables
# Copy this file to .env and fill in your actual values

# VirusTotal API Key (get it from https://www.virustotal.com/)
VT_API_KEY=your_api_key_here

# (Optional) Custom config directory
# VT_CONFIG_DIR=/path/to/config/dir

# (Optional) Enable debug mode
# VT_DEBUG=true
